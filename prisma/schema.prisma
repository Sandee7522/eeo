generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ScrapeHistory {
  id           String   @id @default(uuid())
  query        String
  queryType    String?
  source       String?

  country      String?
  state        String?
  city         String?

  maxResults   Int
  saved        Int
  failed       Int
  duplicates   Int      @default(0)
  total        Int

  status       String   @default("completed")
  errorMessage String?

  retries      Int      @default(0)
  durationSec  Int?

  userId       String?
  savedToTable String?

  createdAt    DateTime @default(now())
  startedAt    DateTime?
  endedAt      DateTime?
}

model Company {
  id           String   @id @default(uuid())
  name         String
  category     String?
  address      String
  city         String?
  state        String?
  country      String?
  latitude     Float?
  longitude    Float?
  phone        String?
  website      String?
  email        String?
  rating       Float?
  totalReviews Int?
  priceLevel   Int?
  status       String?
  description  String?
  openingHours Json?
  photos       Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  locationKey  String?  @unique
}

model RemoteJob {
  id             String   @id @default(uuid())
  jobTitle       String
  companyName    String
  jobUrl         String   @db.Text
  applyUrl       String?  @db.Text
  location       String?
  salary         String?
  tags           Json?
  postedDate     String?
  companyWebsite String?  @db.Text
  emails         Json?
  phoneNumbers   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([jobTitle, companyName])
}
