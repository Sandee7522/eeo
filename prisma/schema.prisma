generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// #################################     Users         ###############################  

model User {
  id          String       @id @default(uuid())
  name        String
  email       String       @unique
  password    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model StateGovernment {
  id           String   @id @default(uuid())

  stateName    String   @unique
  stateLogo    String?

  partyName    String
  partyFlag    String?
  partyColor   String?

  description  String?  @db.Text

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model StatePolitics {
  id                  String   @id @default(uuid())

  stateName           String   @unique

  governingParty      String
  governingAlliance   String?

  oppositionParty     String?
  oppositionAlliance  String?

  otherOpposition     String?

  latestElectionYear  Int?

  stateLogo           String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}